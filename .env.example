# =========================
# Redis
# =========================
REDIS_URL=redis://redis:6379/0
REDIS_POOL_MAX_CONNECTIONS=20
TASK_QUEUE_PREFIX=bridge:tasks
TASK_DEFAULT_MAX_ATTEMPTS=5
TASK_DEFAULT_LEASE_SECONDS=300
TASK_RETRY_BASE_SECONDS=30
TASK_RETRY_MAX_SECONDS=1800
TASK_IDEMPOTENCY_TTL_SECONDS=604800

# =========================
# CORS Middleware
# =========================
ALLOWED_ORIGIN_REGEX=.*
ALLOW_CREDENTIALS=false
ALLOW_METHODS=["*"]
ALLOW_HEADERS=["*"]

# =========================
# Postgres
# =========================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eimzo_db

# =========================
# API
# =========================
API_PORT=8000

# =========================
# Google Sheets
# =========================
SERVICE_ACCOUNT_FILE=/service_account.json
SHEET_SCOPES=["https://www.googleapis.com/auth/spreadsheets","https://www.googleapis.com/auth/drive"]
SHEET_ID=your_google_sheet_id

# =========================
# Logging
# =========================
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_TO_CONSOLE=true
